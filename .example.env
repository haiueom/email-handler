# Discord webhook URL for email notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<id>/<token>

# Public URL of the deployed worker (used for dashboard links in Discord embeds)
DASHBOARD_URL=https://example.workers.dev

# Fallback email address — raw email is forwarded here if processing fails
FALLBACK_EMAIL=you@example.com

# Cloudflare Access (JWT auth) — required, dashboard is inaccessible without these
TEAM_DOMAIN=https://yourteam.cloudflareaccess.com
AUDIENCE_TAG=your-audience-tag
